# RECURSIVE BREADTH FIRST SEARCH 
import math


graph = {
    "Ratnagiri": {
        "Chiplun": 130
    },

    "Chiplun": {
        "Ratnagiri": 130,
        "Mahad": 90,
        "Satara": 120
    },

    "Mahad": {
        "Chiplun": 90,
        "Panvel": 75
    },

    "Satara": {
        "Chiplun": 120
    },

    "Panvel": {
        "Mahad": 75,
        "Mumbai": 40
    },

    "Mumbai": {}
}

heuristic = {
    "Ratnagiri": 300,
    "Chiplun": 220,
    "Mahad": 110,
    "Satara": 250,
    "Panvel": 40,
    "Mumbai": 0
}



def rbfs(node, goal, g_cost, f_limit, path):

    if node == goal:
        return path, g_cost

    successors = []

    for neighbor, distance in graph[node].items():

        if neighbor not in path:

            new_g = g_cost + distance
            new_f = max(new_g + heuristic[neighbor],
                        g_cost + heuristic[node])

            successors.append([neighbor, new_g, new_f])

    if len(successors) == 0:
        return None, math.inf

    while True:

        successors.sort(key=lambda x: x[2])

        best = successors[0]

        if best[2] > f_limit:
            return None, best[2]

        if len(successors) > 1:
            alternative = successors[1][2]
        else:
            alternative = math.inf

        result, best[2] = rbfs(
            best[0],
            goal,
            best[1],
            min(f_limit, alternative),
            path + [best[0]]
        )

        if result is not None:
            return result, best[1]



start_city = "Ratnagiri"
goal_city = "Mumbai"

path, cost = rbfs(
    start_city,
    goal_city,
    0,
    math.inf,
    [start_city]
)

print("===== Recursive Best-First Search =====")
print("Route Found :", " -> ".join(path))
print("Total Distance :", cost, "km")


